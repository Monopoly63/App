<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:padding="16dp"
    android:background="@drawable/widget_glass_bg">

    <ImageView
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:background="@drawable/widget_art_bg"
        android:src="@drawable/ic_widget_note"
        android:padding="15dp"
        android:tint="#F6F1E8" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingStart="14dp"
        android:paddingEnd="10dp">
        <TextView
            android:id="@+id/widget_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Hablas"
            android:textColor="#F6F1E8"
            android:textSize="15sp"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end" />
        <TextView
            android:id="@+id/widget_artist"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Native glass music player"
            android:textColor="#88FFFFFF"
            android:textSize="12sp"
            android:maxLines="1"
            android:ellipsize="end" />
    </LinearLayout>

    <ImageButton
        android:id="@+id/widget_previous"
        android:layout_width="38dp"
        android:layout_height="38dp"
        android:background="@drawable/widget_button_bg"
        android:src="@drawable/ic_widget_previous"
        android:tint="#F6F1E8" />
    <ImageButton
        android:id="@+id/widget_play_pause"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:layout_marginStart="8dp"
        android:background="@drawable/widget_button_bg"
        android:src="@drawable/ic_widget_play"
        android:tint="#F6F1E8" />
    <ImageButton
        android:id="@+id/widget_next"
        android:layout_width="38dp"
        android:layout_height="38dp"
        android:layout_marginStart="8dp"
        android:background="@drawable/widget_button_bg"
        android:src="@drawable/ic_widget_next"
        android:tint="#F6F1E8" />
</LinearLayout>
